---
import { readAll } from '../lib/markdoc/read';
import { blog } from '../lib/markdoc/frontmatter.schema';
import PageLayout from '../layouts/PageLayout.astro';
import PageMeta from '../components/PageMeta.astro';
import { SITE_TITLE } from '../config';
import { getNotionPosts } from '../lib/notion';

const markdownPosts = await readAll({
  directory: 'blog',
  frontmatterSchema: blog,
});

const notionPosts = await getNotionPosts();

// Normalize both sources into a unified format
type UnifiedPost = {
  title: string;
  date: Date;
  href: string;
  external: boolean;
  externalUrl?: string;
  source: 'markdown' | 'notion';
};

const allPosts: UnifiedPost[] = [
  ...markdownPosts
    .filter((p) => p.frontmatter.draft !== true)
    .map((post) => ({
      title: post.frontmatter.title,
      date: new Date(post.frontmatter.date),
      href: post.frontmatter.external ? '' : `/blog/${post.slug}`,
      external: !!post.frontmatter.external,
      externalUrl: post.frontmatter.external ? post.frontmatter.url : undefined,
      source: 'markdown' as const,
    })),
  ...notionPosts.map((post) => ({
    title: post.title,
    date: post.pubDate || new Date(),
    href: `/notion/${post.slug}`,
    external: false,
    source: 'notion' as const,
  })),
];

const sortedPosts = allPosts.sort(
  (a, b) => b.date.valueOf() - a.date.valueOf()
);
---

<PageLayout>
  <PageMeta title={`Blog | ${SITE_TITLE}`} slot="meta" />
  <section slot="main">
    <ul>
      {
        sortedPosts.map((post) => {
          const formattedDate = post.date.toLocaleDateString('en-us', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });
          return (
            <li class="grid grid-cols-[1fr] md:grid-cols-[1fr_auto] mb-3 md:gap-2 items-start">
              <div class="title">
                {post.external ? (
                  <a
                    href={post.externalUrl}
                    target="_blank"
                    class="unset
                        transition-[background-size] duration-300
                        bg-gradient-to-r bg-left-bottom bg-no-repeat
                        bg-[length:0%_55%] hover:bg-[length:100%_55%] dark:bg-[length:0%_2px] hover:dark:bg-[length:100%_2px]
                        from-primary-blue to-primary-blue dark:from-primary-blue dark:to-primary-blue
                      "
                  >
                    <span>{post.title}</span>
                    <span>
                      <i class="ml-1 mr-1 text-[12px] pb-2 fa-solid fa-up-right-from-square" />
                    </span>
                  </a>
                ) : (
                  <a
                    href={post.href}
                    class="unset
                        transition-[background-size] duration-300
                        bg-gradient-to-r bg-left-bottom bg-no-repeat
                        bg-[length:0%_55%] hover:bg-[length:100%_55%] dark:bg-[length:0%_2px] hover:dark:bg-[length:100%_2px]
                        from-primary-blue to-primary-blue dark:from-primary-blue dark:to-primary-blue
                      "
                  >
                    {post.title}
                  </a>
                )}
              </div>
              <div class="text-text-muted text-sm italic pt-1">
                <time datetime={post.date.toISOString()}>
                  {formattedDate}
                </time>
              </div>
            </li>
          );
        })
      }
    </ul>
  </section>
</PageLayout>
